<IfModule mod_mime.c>
  AddType font/woff .woff
  AddType font/woff2 .woff2
  AddType font/ttf .ttf
  AddType font/otf .otf
  AddType application/vnd.ms-fontobject .eot
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(woff|woff2|ttf|otf|eot)$">
    Header set Access-Control-Allow-Origin "*"
    Header set Cache-Control "public, max-age=31536000"
  </FilesMatch>
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Never rewrite static assets (including icon font files)
  RewriteRule ^assets/ - [L,NC]
  RewriteRule \.(css|js|mjs|map|json|png|jpg|jpeg|gif|svg|webp|ico|woff|woff2|ttf|otf|eot)$ - [L,NC]

  # Do not rewrite backend API requests
  RewriteCond %{REQUEST_URI} !^/backend/

  # Do not rewrite existing files/directories
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # SPA fallback
  RewriteRule . /index.html [L]
</IfModule>
